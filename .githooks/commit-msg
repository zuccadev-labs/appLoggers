#!/bin/sh
# Conventional Commits enforcer — runs on `git commit`
# Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
#
# Format: <type>[optional scope]: <description>
# Examples:
#   feat(core): add exponential backoff
#   fix(transport): handle HTTP 429
#   docs: update README with iOS setup

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9\-]+\))?!?: .{1,100}$"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo ""
    echo "ERROR: Commit message does not follow Conventional Commits format."
    echo ""
    echo "  Expected: <type>[optional scope]: <description>"
    echo "  Types:    feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"
    echo ""
    echo "  Examples:"
    echo "    feat(core): add exponential backoff"
    echo "    fix(transport): handle HTTP 429 retry"
    echo "    docs: update README with iOS setup guide"
    echo ""
    echo "  Your message: $COMMIT_MSG"
    echo ""
    exit 1
fi
